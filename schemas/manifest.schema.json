{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/ajsai47/autocode/schemas/manifest.schema.json",
  "title": "AutoCode Manifest",
  "description": "Configuration contract for the AutoCode autonomous code factory. Generated by /autocode-bootstrap, consumed by all agents.",
  "type": "object",
  "required": ["version", "repo", "commands", "guardrails"],
  "properties": {
    "version": {
      "type": "integer",
      "const": 1,
      "description": "Manifest schema version"
    },
    "repo": {
      "type": "object",
      "required": ["name", "language", "default_branch"],
      "properties": {
        "name": {
          "type": "string",
          "description": "Repository name"
        },
        "language": {
          "type": "string",
          "enum": ["typescript", "javascript", "python", "rust", "go", "java", "kotlin", "swift", "ruby", "php", "csharp", "cpp"],
          "description": "Primary language"
        },
        "framework": {
          "type": ["string", "null"],
          "description": "Primary framework (e.g., next, express, fastapi, actix, gin)"
        },
        "monorepo": {
          "type": "boolean",
          "default": false,
          "description": "Whether this is a monorepo with workspaces"
        },
        "default_branch": {
          "type": "string",
          "default": "main",
          "description": "Default branch name"
        }
      }
    },
    "commands": {
      "type": "object",
      "required": ["test"],
      "properties": {
        "install": {
          "type": ["string", "null"],
          "description": "Install dependencies command"
        },
        "test": {
          "type": "string",
          "description": "Run tests command"
        },
        "coverage": {
          "type": ["string", "null"],
          "description": "Run coverage command"
        },
        "typecheck": {
          "type": ["string", "null"],
          "description": "Type checking command"
        },
        "lint": {
          "type": ["string", "null"],
          "description": "Lint command"
        },
        "build": {
          "type": ["string", "null"],
          "description": "Build command"
        }
      }
    },
    "coverage": {
      "type": ["object", "null"],
      "properties": {
        "tool": {
          "type": ["string", "null"],
          "enum": ["v8", "istanbul", "coverage.py", "tarpaulin", "go-cover", "jacoco", null],
          "description": "Coverage tool in use"
        },
        "current": {
          "type": "object",
          "properties": {
            "statements": { "type": "number" },
            "branches": { "type": "number" },
            "functions": { "type": "number" },
            "lines": { "type": "number" }
          }
        },
        "targets": {
          "type": "object",
          "properties": {
            "statements": { "type": "number", "default": 80 },
            "branches": { "type": "number", "default": 70 },
            "functions": { "type": "number", "default": 80 },
            "lines": { "type": "number", "default": 80 }
          }
        },
        "gaps": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["file", "coverage", "priority"],
            "properties": {
              "file": {
                "type": "string",
                "description": "Relative path to the file"
              },
              "coverage": {
                "type": "number",
                "minimum": 0,
                "maximum": 100,
                "description": "Current coverage percentage"
              },
              "priority": {
                "type": "integer",
                "minimum": 1,
                "description": "Priority rank (1 = highest)"
              }
            }
          }
        }
      }
    },
    "scoring": {
      "type": ["object", "null"],
      "properties": {
        "formula": {
          "type": "string",
          "default": "(merge_rate * 0.4) + (coverage_delta * 0.3) + ((1 - regression_rate) * 0.3)",
          "description": "Scoring formula for cycle quality"
        },
        "weights_rationale": {
          "type": "string",
          "description": "Why these weights were chosen"
        }
      }
    },
    "guardrails": {
      "type": "object",
      "properties": {
        "immutable_patterns": {
          "type": "array",
          "items": { "type": "string" },
          "default": ["*.config.*", "*.env*", ".github/**", "autocode.manifest.json"],
          "description": "Glob patterns for files agents must never modify"
        },
        "max_files_per_pr": {
          "type": "integer",
          "default": 5,
          "minimum": 1,
          "description": "Maximum files changed in a single PR"
        },
        "max_lines_changed": {
          "type": "integer",
          "default": 200,
          "minimum": 10,
          "description": "Maximum lines changed in a single PR"
        }
      }
    },
    "time_budgets": {
      "type": ["object", "null"],
      "properties": {
        "scout_seconds": { "type": "integer", "default": 180 },
        "architect_seconds": { "type": "integer", "default": 180 },
        "builder_seconds": { "type": "integer", "default": 600 },
        "tester_seconds": { "type": "integer", "default": 600 },
        "reviewer_seconds": { "type": "integer", "default": 300 },
        "cycle_max_seconds": { "type": "integer", "default": 1800 }
      }
    },
    "difficulty": {
      "type": ["object", "null"],
      "properties": {
        "current_level": {
          "type": "integer",
          "default": 1,
          "minimum": 1,
          "maximum": 6
        },
        "levels": {
          "type": "object",
          "properties": {
            "1": { "type": "string", "default": "Pure function coverage (no mocking)" },
            "2": { "type": "string", "default": "Utility/helper coverage (light mocking)" },
            "3": { "type": "string", "default": "Fix existing failing tests" },
            "4": { "type": "string", "default": "Integration coverage (DB, API mocks)" },
            "5": { "type": "string", "default": "Feature implementation from tickets" },
            "6": { "type": "string", "default": "Refactoring with behavior preservation" }
          }
        },
        "advance_when": {
          "type": "string",
          "default": "3 consecutive successful cycles at current level"
        }
      }
    },
    "model_routing": {
      "type": ["object", "null"],
      "properties": {
        "scout": { "type": "string", "default": "haiku" },
        "architect": { "type": "string", "default": "sonnet" },
        "builder": { "type": "string", "default": "opus" },
        "tester": { "type": "string", "default": "sonnet" },
        "reviewer": { "type": "string", "default": "opus" }
      }
    }
  }
}
