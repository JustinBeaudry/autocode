{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/ajsai47/autocode/schemas/manifest.schema.json",
  "title": "AutoCode Manifest",
  "description": "Configuration contract for the AutoCode autonomous code factory. Generated by /autocode-bootstrap, consumed by all agents.",
  "type": "object",
  "required": ["version", "repo", "commands", "guardrails"],
  "properties": {
    "version": {
      "type": "integer",
      "const": 1,
      "description": "Manifest schema version"
    },
    "repo": {
      "type": "object",
      "required": ["name", "language", "default_branch"],
      "properties": {
        "name": {
          "type": "string",
          "description": "Repository name"
        },
        "language": {
          "type": "string",
          "enum": ["typescript", "javascript", "python", "rust", "go", "java", "kotlin", "swift", "ruby", "php", "csharp", "cpp"],
          "description": "Primary language"
        },
        "framework": {
          "type": ["string", "null"],
          "description": "Primary framework (e.g., next, express, fastapi, actix, gin)"
        },
        "monorepo": {
          "type": "boolean",
          "default": false,
          "description": "Whether this is a monorepo with workspaces"
        },
        "default_branch": {
          "type": "string",
          "default": "main",
          "description": "Default branch name"
        }
      }
    },
    "commands": {
      "type": "object",
      "required": ["test"],
      "properties": {
        "install": {
          "type": ["string", "null"],
          "description": "Install dependencies command"
        },
        "test": {
          "type": "string",
          "description": "Run tests command"
        },
        "coverage": {
          "type": ["string", "null"],
          "description": "Run coverage command"
        },
        "typecheck": {
          "type": ["string", "null"],
          "description": "Type checking command"
        },
        "lint": {
          "type": ["string", "null"],
          "description": "Lint command"
        },
        "build": {
          "type": ["string", "null"],
          "description": "Build command"
        }
      }
    },
    "coverage": {
      "type": ["object", "null"],
      "properties": {
        "tool": {
          "type": ["string", "null"],
          "enum": ["v8", "istanbul", "pytest-cov", "tarpaulin", "go-cover", null],
          "description": "Coverage tool in use"
        },
        "current": {
          "type": "object",
          "properties": {
            "statements": { "type": "number" },
            "branches": { "type": "number" },
            "functions": { "type": "number" },
            "lines": { "type": "number" }
          }
        },
        "targets": {
          "type": "object",
          "properties": {
            "statements": { "type": "number", "default": 80 },
            "branches": { "type": "number", "default": 70 },
            "functions": { "type": "number", "default": 80 },
            "lines": { "type": "number", "default": 80 }
          }
        },
        "gaps": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["file", "coverage", "priority"],
            "properties": {
              "file": {
                "type": "string",
                "description": "Relative path to the file"
              },
              "coverage": {
                "type": "number",
                "minimum": 0,
                "maximum": 100,
                "description": "Current coverage percentage"
              },
              "priority": {
                "type": "integer",
                "minimum": 1,
                "description": "Priority rank (1 = highest)"
              },
              "type": {
                "type": "string",
                "enum": ["pure_function", "utility", "handler", "service", "middleware", "infrastructure"],
                "description": "Classification of the file type"
              },
              "complexity": {
                "type": "string",
                "enum": ["low", "medium", "high"],
                "description": "Estimated complexity of the file"
              }
            }
          }
        }
      }
    },
    "guardrails": {
      "type": "object",
      "properties": {
        "immutable_patterns": {
          "type": "array",
          "items": { "type": "string" },
          "default": ["*.config.*", "*.env*", ".github/**", "autocode.manifest.json"],
          "description": "Glob patterns for files agents must never modify"
        },
        "max_files_per_pr": {
          "type": "integer",
          "default": 5,
          "minimum": 1,
          "description": "Maximum files changed in a single PR"
        },
        "max_lines_changed": {
          "type": "integer",
          "default": 200,
          "minimum": 10,
          "description": "Maximum lines changed in a single PR"
        }
      }
    },
    "time_budgets": {
      "type": ["object", "null"],
      "properties": {
        "scout_seconds": { "type": "integer", "default": 180 },
        "architect_seconds": { "type": "integer", "default": 180 },
        "builder_seconds": { "type": "integer", "default": 600 },
        "tester_seconds": { "type": "integer", "default": 600 },
        "reviewer_seconds": { "type": "integer", "default": 300 },
        "cycle_max_seconds": { "type": "integer", "default": 1800, "description": "Maximum total session time in seconds (not per-cycle). Factory stops after this duration." }
      }
    },
    "difficulty": {
      "type": ["object", "null"],
      "properties": {
        "current_level": {
          "type": "integer",
          "default": 1,
          "minimum": 1,
          "maximum": 6
        },
        "levels": {
          "type": "object",
          "properties": {
            "1": { "type": "string", "default": "Pure function coverage (no mocking)" },
            "2": { "type": "string", "default": "Utility/helper coverage (light mocking)" },
            "3": { "type": "string", "default": "Fix existing failing tests" },
            "4": { "type": "string", "default": "Integration coverage (DB, API mocks)" },
            "5": { "type": "string", "default": "Feature implementation from tickets" },
            "6": { "type": "string", "default": "Refactoring with behavior preservation" }
          }
        },
        "advance_when": {
          "type": "string",
          "default": "3 consecutive successful cycles at current level"
        }
      }
    },
    "model_routing": {
      "type": ["object", "null"],
      "properties": {
        "scout": {
          "oneOf": [
            { "type": "string" },
            {
              "type": "object",
              "required": ["model"],
              "properties": {
                "model": { "type": "string" },
                "reasoning": { "type": "boolean", "default": false }
              },
              "additionalProperties": false
            }
          ],
          "default": "sonnet",
          "description": "Model for the Scout agent (read-only codebase exploration). Default: sonnet. Sonnet recommended. Haiku may fail on repos with many MCP tools due to schema size limits."
        },
        "architect": {
          "oneOf": [
            { "type": "string" },
            {
              "type": "object",
              "required": ["model"],
              "properties": {
                "model": { "type": "string" },
                "reasoning": { "type": "boolean", "default": false }
              },
              "additionalProperties": false
            }
          ],
          "default": "sonnet",
          "description": "Model for the Architect agent (spec writing, L3+ only). Default: sonnet."
        },
        "builder": {
          "oneOf": [
            { "type": "string" },
            {
              "type": "object",
              "required": ["model"],
              "properties": {
                "model": { "type": "string" },
                "reasoning": { "type": "boolean", "default": true }
              },
              "additionalProperties": false
            }
          ],
          "default": "opus",
          "description": "Model for the Builder agent (implementation). Default: opus."
        },
        "tester": {
          "oneOf": [
            { "type": "string" },
            {
              "type": "object",
              "required": ["model"],
              "properties": {
                "model": { "type": "string" },
                "reasoning": { "type": "boolean", "default": false }
              },
              "additionalProperties": false
            }
          ],
          "default": "sonnet",
          "description": "Model for the Tester agent (test writing, L3+ only). Default: sonnet."
        },
        "reviewer": {
          "oneOf": [
            { "type": "string" },
            {
              "type": "object",
              "required": ["model"],
              "properties": {
                "model": { "type": "string" },
                "reasoning": { "type": "boolean", "default": true }
              },
              "additionalProperties": false
            }
          ],
          "default": "opus",
          "description": "Model for the Reviewer agent (quality gate). Default: opus."
        },
        "planner": {
          "oneOf": [
            { "type": "string" },
            {
              "type": "object",
              "required": ["model"],
              "properties": {
                "model": { "type": "string" },
                "reasoning": { "type": "boolean", "default": false }
              },
              "additionalProperties": false
            }
          ],
          "default": "sonnet",
          "description": "Model for the Planner agent (task decomposition into multi-PR plans). Default: sonnet."
        },
        "discoverer": {
          "oneOf": [
            { "type": "string" },
            {
              "type": "object",
              "required": ["model"],
              "properties": {
                "model": { "type": "string" },
                "reasoning": { "type": "boolean", "default": false }
              },
              "additionalProperties": false
            }
          ],
          "default": "sonnet",
          "description": "Model for the Discoverer agent (proactive codebase discovery). Default: sonnet."
        }
      },
      "additionalProperties": false
    },
    "ignore_diminishing_returns": {
      "type": "boolean",
      "default": false,
      "description": "When true, the factory continues even when coverage improvements are less than 0.5% for 5 consecutive cycles"
    },
    "parallel": {
      "type": "integer",
      "default": 1,
      "minimum": 1,
      "maximum": 5,
      "description": "Number of parallel pipelines to run simultaneously. Each pipeline gets its own worktree."
    },
    "work_sources": {
      "type": ["object", "null"],
      "description": "Configuration for work item sources beyond coverage gaps",
      "properties": {
        "coverage_gaps": {
          "type": "boolean",
          "default": true,
          "description": "Whether to include coverage gaps as work items"
        },
        "github_issues": {
          "type": ["object", "null"],
          "properties": {
            "enabled": {
              "type": "boolean",
              "default": false,
              "description": "Whether to ingest GitHub Issues labeled for AutoCode"
            },
            "labels": {
              "type": "array",
              "items": { "type": "string" },
              "default": ["autocode"],
              "description": "Issue labels to filter for"
            },
            "exclude_labels": {
              "type": "array",
              "items": { "type": "string" },
              "default": ["wontfix", "duplicate"],
              "description": "Issue labels to exclude"
            }
          }
        },
        "backlog": {
          "type": "boolean",
          "default": true,
          "description": "Whether to read .autocode/backlog.md for work items"
        },
        "pr_reviews": {
          "type": "boolean",
          "default": true,
          "description": "Whether to pick up unaddressed PR review comments"
        },
        "tech_debt": {
          "type": "boolean",
          "default": false,
          "description": "Whether to scan for TODO/FIXME comments as work items"
        }
      }
    },
    "brain": {
      "type": ["object", "null"],
      "description": "Persistent brain configuration — controls knowledge graph, pattern database, and human feedback learning",
      "properties": {
        "knowledge_graph": {
          "type": "boolean",
          "default": true,
          "description": "Enable persistent codebase knowledge graph (.autocode/memory/knowledge.json). Scout caches file analysis across sessions."
        },
        "pattern_database": {
          "type": "boolean",
          "default": true,
          "description": "Enable structured pattern database (.autocode/memory/patterns.json). Replaces unstructured lesson scanning with weighted, indexed patterns."
        },
        "human_feedback": {
          "type": "boolean",
          "default": true,
          "description": "Enable human feedback ingestion. Extracts patterns from human PR reviews on merged/closed AutoCode PRs."
        },
        "pattern_retention_days": {
          "type": "integer",
          "default": 90,
          "minimum": 7,
          "description": "How long patterns are retained before being pruned. Older patterns receive lower weight in retrieval."
        },
        "constraint_violations": {
          "type": "boolean",
          "default": true,
          "description": "Enable adaptive constraint violation tracking (.autocode/memory/constraint_violations.json). Weights Layer 6 repetition by historical violation frequency."
        }
      }
    },
    "ci": {
      "type": ["object", "null"],
      "description": "CI-aware shipping configuration — controls auto-fix behavior when CI fails after merge",
      "properties": {
        "auto_fix": {
          "type": "boolean",
          "default": true,
          "description": "When CI fails after merge, attempt to fix the failure before reverting. If false, reverts immediately (v2 behavior)."
        },
        "max_fix_attempts": {
          "type": "integer",
          "default": 2,
          "minimum": 1,
          "maximum": 5,
          "description": "Maximum number of fix attempts before falling back to revert."
        },
        "fixable_categories": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["test_failure", "type_error", "lint_error", "build_error"]
          },
          "default": ["test_failure", "type_error", "lint_error", "build_error"],
          "description": "CI failure categories that AutoCode will attempt to fix. Categories not listed here trigger immediate revert."
        }
      }
    },
    "planning": {
      "type": ["object", "null"],
      "description": "Multi-PR planning configuration — decompose large tasks into dependency graphs of atomic PRs",
      "properties": {
        "enabled": {
          "type": "boolean",
          "default": true,
          "description": "Whether multi-PR planning is active"
        },
        "max_steps_per_plan": {
          "type": "integer",
          "default": 10,
          "minimum": 2,
          "maximum": 20,
          "description": "Maximum steps in a single plan (prevents over-decomposition)"
        },
        "auto_plan_issues": {
          "type": "boolean",
          "default": false,
          "description": "When true, large GitHub Issues (body > 500 chars with multiple file paths) are automatically decomposed by the Planner instead of treated as single work items"
        }
      }
    },
    "daemon": {
      "type": ["object", "null"],
      "description": "Daemon mode configuration — run AutoCode on a schedule via GitHub Actions with budget controls",
      "properties": {
        "enabled": {
          "type": "boolean",
          "default": false,
          "description": "Whether daemon mode is active"
        },
        "schedule": {
          "type": "string",
          "default": "0 */6 * * *",
          "description": "Cron expression for when to run (default: every 6 hours)"
        },
        "max_cycles_per_run": {
          "type": "integer",
          "default": 5,
          "minimum": 1,
          "maximum": 50,
          "description": "Hard limit on cycles per daemon invocation"
        },
        "daily_budget_usd": {
          "type": "number",
          "default": 10.00,
          "minimum": 1.00,
          "description": "Stop if today's estimated spend exceeds this amount"
        },
        "deploy_windows": {
          "type": "array",
          "items": { "type": "string" },
          "default": [],
          "description": "Array of cron expressions during which AutoCode should NOT run (e.g., deploy windows)"
        },
        "notifications": {
          "type": "object",
          "properties": {
            "on_failure": {
              "type": "string",
              "enum": ["github_issue", "pr_comment", "none"],
              "default": "github_issue"
            },
            "on_success": {
              "type": "string",
              "enum": ["github_issue", "pr_comment", "none"],
              "default": "none"
            },
            "on_budget_exceeded": {
              "type": "string",
              "enum": ["github_issue", "pr_comment", "none"],
              "default": "github_issue"
            }
          }
        }
      }
    },
    "discovery": {
      "type": ["object", "null"],
      "description": "Proactive discovery configuration — find work that needs doing without being told",
      "properties": {
        "enabled": {
          "type": "boolean",
          "default": false,
          "description": "Master switch for proactive discovery (runs once per session or daemon run)"
        },
        "modules": {
          "type": "object",
          "properties": {
            "untested_changes": {
              "type": "boolean",
              "default": true,
              "description": "Detect recent commits that modified code without corresponding tests"
            },
            "complexity_hotspots": {
              "type": "boolean",
              "default": true,
              "description": "Find files that have grown beyond complexity thresholds"
            },
            "dependency_audit": {
              "type": "boolean",
              "default": true,
              "description": "Check for known vulnerabilities and outdated dependencies"
            },
            "stale_todos": {
              "type": "boolean",
              "default": true,
              "description": "Find TODO/FIXME comments that have been open too long"
            }
          }
        },
        "complexity_threshold_lines": {
          "type": "integer",
          "default": 300,
          "minimum": 100,
          "description": "Files above this line count trigger refactor suggestions"
        },
        "todo_age_days": {
          "type": "integer",
          "default": 30,
          "minimum": 7,
          "description": "How old a TODO must be before it's flagged"
        },
        "max_items_per_module": {
          "type": "integer",
          "default": 5,
          "minimum": 1,
          "maximum": 20,
          "description": "Cap on items each discovery module can create (prevents flooding)"
        }
      }
    },
    "budget": {
      "type": ["object", "null"],
      "description": "Cost control configuration — session caps, per-cycle caps, and budget-aware model downgrading",
      "properties": {
        "session_max_usd": {
          "type": "number",
          "default": 5.00,
          "minimum": 0.50,
          "description": "Hard cap for interactive sessions. Factory stops when estimated spend reaches this amount."
        },
        "cycle_max_usd": {
          "type": "number",
          "default": 2.00,
          "minimum": 0.10,
          "description": "Soft cap per cycle. When remaining budget is below this, Builder and Reviewer downgrade from Opus to Sonnet."
        },
        "warn_at_percent": {
          "type": "integer",
          "default": 80,
          "minimum": 50,
          "maximum": 99,
          "description": "Show a budget warning when this percentage of session_max_usd is spent."
        }
      }
    },
    "testing": {
      "type": ["object", "null"],
      "description": "Detected testing conventions for the project",
      "properties": {
        "file_pattern": {
          "type": "string",
          "description": "How test files are named (e.g., '*.test.ts', '*_test.py')"
        },
        "location": {
          "type": "string",
          "enum": ["co-located", "separate"],
          "description": "Whether test files are co-located with source or in a separate directory"
        },
        "assertion_style": {
          "type": "string",
          "description": "Assertion library/style used (e.g., 'expect/toBe', 'assert', 'assert_eq!')"
        },
        "structure": {
          "type": "string",
          "description": "Test organization pattern (e.g., 'describe/it', 'test()', '#[test]')"
        },
        "helpers": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Paths to shared test utilities or fixtures"
        }
      }
    }
  }
}
